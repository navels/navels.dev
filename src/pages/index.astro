---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>navels.dev</h1>
			<p>
				I'm Lee Nave. I build developer tools and write about agents, evaluation, and the
				craft of shipping software — with a bias toward whether the thing actually works.
			</p>
			<p>
				Start here:
				<a href="/blog/betting-on-the-reviewer/">Betting a coding agent on the reviewer, not the model</a>,
				or browse <a href="/blog">all writing</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
